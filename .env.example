# COOU Digital Student ID System - Environment Configuration
# Copy this file to '.env.local' and replace the values with your actual Firebase project settings.
# All variables are read at BUILD time by Vite (they are baked into the bundle),
# so rebuild/redeploy after changing any of them.

# --- Firebase (required) ---
# Found in Firebase Console > Project Settings > General > Your apps > SDK setup and configuration.
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# --- Application (optional but strongly recommended for production) ---
# Public URL where the app is deployed. Embedded inside every ID card QR code
# so that scanned codes always resolve to the live site. If omitted, QR codes
# use the origin of the browser that generated the card (which would be
# http://localhost:3000 during development - unreachable from a phone).
# No trailing slash. Example: https://coou-id.example.com
VITE_APP_BASE_URL=
