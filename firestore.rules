rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Must stay in sync with INITIAL_ADMINS in src/AuthContext.tsx.
    // Only these accounts may hold an elevated role, so the client-side
    // allow-list is actually enforced by the backend and a tampered client
    // cannot self-promote.
    function isAdminEmail() {
      return isSignedIn() && request.auth.token.email in [
        'nonyeasuzu3@gmail.com',
        'admin@coou.edu.ng'
      ];
    }

    function isAdminOrStaff() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    // Student records: publicly readable so a scanned QR code can be
    // verified from any device without an account. Writes are restricted:
    // admins/staff manage any record; a student may only create a record
    // bearing their own signed-in email, and may only update/delete a record
    // that ALREADY bears their email (so an existing student record can never
    // be overwritten or hijacked by a different account — including writes
    // replayed later by offline synchronization).
    match /students/{studentId} {
      allow read: if true;
      allow create: if isAdminOrStaff() ||
        (isSignedIn() && request.resource.data.email == request.auth.token.email);
      allow update: if isAdminOrStaff() ||
        (isSignedIn() &&
          resource.data.email == request.auth.token.email &&
          request.resource.data.email == request.auth.token.email);
      allow delete: if isAdminOrStaff() ||
        (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // User profiles: each user can only read/write their own profile, and an
    // elevated role (admin/staff) can only be stored for allow-listed emails.
    match /profiles/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId &&
        (!(request.resource.data.role in ['admin', 'staff']) || isAdminEmail());
    }
  }
}
